        "import ast\n",
        "def parse_list(x):\n",
        "    \"\"\"Parser that handles lists, ndarrays, JSON strings, Python repr strings, and NaN.\"\"\"\n",
        "    if x is None:\n",
        "        return []\n",
        "    if isinstance(x, list):\n",
        "        return x\n",
        "    if isinstance(x, np.ndarray):\n",
        "        return x.tolist()\n",
        "    if isinstance(x, float) and np.isnan(x):\n",
        "        return []\n",
        "    if not isinstance(x, str):\n",
        "        return []\n",
        "    s = x.strip()\n",
        "    if s == '' or s.lower() == 'nan':\n",
        "        return []\n",
        "    try:\n",
        "        v = ast.literal_eval(s)\n",
        "        return v if isinstance(v, list) else []\n",
        "    except Exception:\n",
        "        pass\n",
        "    try:\n",
        "        v = json.loads(s)\n",
        "        return v if isinstance(v, list) else []\n",
        "    except Exception:\n",
        "        return []\n",
        "\n",
        "df['ai_use_list']  = df['ai_use'].apply(parse_list)\n",
        "df['ai_want_list'] = df['ai_want'].apply(parse_list)\n",
        "df['ai_risk_list'] = df['ai_risk'].apply(parse_list)\n",
        "\n",
        "# Sanity check\n",
        "df[['ai_use_list','ai_want_list','ai_risk_list']].apply(lambda c: c.apply(len).mean()).round(2)"
      ]
    },
