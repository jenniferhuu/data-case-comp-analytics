      "source": [
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "skep = df[df['cluster3']==-1]\n",
        "order = ['Heavy Adopters','Active Aspirants','Pragmatic Adopters','Light Users',\n",
        "         'Latent Adopters','Stalled Curious','Literacy Gap','AI Resisters']\n",
        "seg_counts = skep['segment'].value_counts().reindex(order).fillna(0).astype(int)\n",
        "\n",
        "cat_color = {'Heavy Adopters': TEAL, 'Active Aspirants': TEAL, 'Pragmatic Adopters': TEAL,\n",
        "             'Light Users': '#6FB7B0', 'Latent Adopters': GOLD, 'Stalled Curious': GOLD,\n",
        "             'Literacy Gap': GOLD, 'AI Resisters': CORAL}\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(11, 5.2), facecolor=PAPER)\n",
        "y = np.arange(len(seg_counts))[::-1]\n",
        "colors = [cat_color[s] for s in seg_counts.index]\n",
        "bars = ax.barh(y, seg_counts.values, color=colors, edgecolor=PAPER, linewidth=2, height=0.72)\n",
        "\n",
        "for bar, val, name in zip(bars, seg_counts.values, seg_counts.index):\n",
        "    pct = val / 142 * 100\n",
        "    note = ''\n",
        "    if name == 'AI Resisters':       note = '  ← only TRUE skeptics'\n",
        "    if name == 'Active Aspirants': note = '  ← heavy AI users'\n",
        "    if name == 'Heavy Adopters':      note = '  ← heavy AI users'\n",
        "    ax.text(bar.get_width()+1, bar.get_y()+bar.get_height()/2,\n",
        "            f'{val}  ({pct:.0f}%){note}',\n",
        "            va='center', fontsize=11, color=INK, fontweight='bold')\n",
        "\n",
        "ax.set_yticks(y); ax.set_yticklabels(seg_counts.index, fontsize=11)\n",
        "ax.set_xlim(0, 60)\n",
