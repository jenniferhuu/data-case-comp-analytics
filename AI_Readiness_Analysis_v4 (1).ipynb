      "source": [
        "# --- Nonprofit-only frame for the narrative ---\n",
        "df_np = df[df['nonprofit'].fillna(0).astype(int) == 1].copy()\n",
        "\n",
        "# Make this section self-contained\n",
        "if 'n_wants' not in df_np.columns:\n",
        "    df_np['n_wants'] = df_np['ai_want_list'].apply(\n",
        "        lambda r: len([\n",
        "            x for x in r\n",
        "            if 'know yet' not in str(x).lower() and 'other' not in str(x).lower()\n",
        "        ])\n",
        "    )\n",
        "\n",
        "if 'not_using' not in df_np.columns:\n",
        "    df_np['not_using'] = df_np['ai_use_list'].apply(\n",
        "        lambda r: any('not currently using' in str(x).lower() for x in r)\n",
        "    )\n",
        "\n",
        "CREATIVE_CATS    = ['Generate content', 'Chatbot Q&A', 'Translate / transcribe']\n",
        "OPERATIONAL_CATS = ['Organize data', 'Automate tasks', 'Interpret data', 'Predict outcomes']\n",
        "ORDERED_NARRATIVE_CATS = CREATIVE_CATS + OPERATIONAL_CATS\n",
        "\n",
        "# --- Mention-share math ---\n",
        "# Numerator: how many \"creative\" / \"operational\" categorized mentions appear across\n",
        "#            all nonprofit respondents.\n",
        "# Denominator: total mentions in the raw use/want list, EXCLUDING the\n",
        "#              \"Not currently using AI\" placeholder (so the denominator reflects\n",
        "#              actual AI activity / desire, not the opt-out).\n",
        "# Anything in the list that isn't one of the 7 categories falls into \"Other\"\n",
        "# (e.g., \"Other\", \"Don't know yet\" for wants).\n",
        "\n",
        "def is_skip_marker(val):\n",
        "    s = str(val).lower()\n",
        "    return 'not currently using' in s\n",
        "\n",
        "# Use side\n",
        "current_users_np = df_np[~df_np['not_using']].copy()\n",
        "total_use_mentions = current_users_np['ai_use_list'].apply(\n",
        "    lambda r: sum(1 for x in r if not is_skip_marker(x))\n",
        ").sum()\n",
        "creative_use_mentions = sum(\n",
        "    current_users_np[f'use_{c}'].sum() for c in CREATIVE_CATS\n",
        ")\n",
        "operational_use_mentions = sum(\n",
        "    current_users_np[f'use_{c}'].sum() for c in OPERATIONAL_CATS\n",
        ")\n",
        "other_use_mentions = total_use_mentions - creative_use_mentions - operational_use_mentions\n",
        "\n",
        "# Want side\n",
        "demand_np = df_np[df_np['n_wants'] > 0].copy()\n",
        "total_want_mentions = demand_np['ai_want_list'].apply(\n",
        "    lambda r: sum(1 for x in r if not is_skip_marker(x))\n",
        ").sum()\n",
        "creative_want_mentions = sum(\n",
        "    demand_np[f'want_{c}'].sum() for c in CREATIVE_CATS\n",
        ")\n",
        "operational_want_mentions = sum(\n",
        "    demand_np[f'want_{c}'].sum() for c in OPERATIONAL_CATS\n",
        ")\n",
        "other_want_mentions = total_want_mentions - creative_want_mentions - operational_want_mentions\n",
        "\n",
        "creative_operational_mix = pd.DataFrame([\n",
        "    {\n",
        "        'stage': 'Current AI-use mentions',\n",
        "        'creative_pct':    creative_use_mentions    / total_use_mentions * 100,\n",
        "        'operational_pct': operational_use_mentions / total_use_mentions * 100,\n",
        "        'other_pct':       other_use_mentions       / total_use_mentions * 100,\n",
        "    },\n",
        "    {\n",
        "        'stage': 'Desired AI-use mentions',\n",
        "        'creative_pct':    creative_want_mentions    / total_want_mentions * 100,\n",
        "        'operational_pct': operational_want_mentions / total_want_mentions * 100,\n",
        "        'other_pct':       other_want_mentions       / total_want_mentions * 100,\n",
        "    },\n",
        "])\n",
        "\n",
        "display(creative_operational_mix.round(1))\n",
        "print(\n",
        "    f\"Current AI-use mentions: \"\n",
        "    f\"{creative_operational_mix.loc[0, 'creative_pct']:.1f}% creative vs \"\n",
        "    f\"{creative_operational_mix.loc[0, 'operational_pct']:.1f}% operational\"\n",
        ")\n",
        "print(\n",
        "    f\"Desired AI-use mentions: \"\n",
        "    f\"{creative_operational_mix.loc[1, 'operational_pct']:.1f}% operational vs \"\n",
        "    f\"{creative_operational_mix.loc[1, 'creative_pct']:.1f}% creative\"\n",
        ")\n"
      ]
    },
