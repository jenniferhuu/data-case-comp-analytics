        "# --- Imports ---\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import json\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib as mpl\n",
        "from collections import Counter\n",
        "from pathlib import Path\n",
        "\n",
        "pd.set_option('display.max_columns', 100)\n",
        "pd.set_option('display.width', 200)\n",
        "\n",
        "# --- Palette (kept consistent with the presentation deck) ---\n",
        "INK    = '#1A1F36'   # ink / deep navy\n",
        "INK2   = '#2D3454'   # softer ink\n",
        "CORAL  = '#E85D5D'   # coral — friction / skeptic\n",
        "GOLD   = '#F4B860'   # gold — late adopter / aspiration\n",
        "TEAL   = '#3FA89B'   # teal — consumer / action\n",
        "CREAM  = '#F5EFE0'\n",
        "PAPER  = '#FAF6EC'   # background\n",
        "MUTED  = '#8A8FA3'   # muted gray-blue\n",
        "\n",
        "# --- Plot defaults ---\n",
        "mpl.rcParams['font.family']     = 'DejaVu Sans'\n",
        "mpl.rcParams['axes.edgecolor']  = INK2\n",
        "mpl.rcParams['axes.labelcolor'] = INK\n",
        "mpl.rcParams['xtick.color']     = INK2\n",
        "mpl.rcParams['ytick.color']     = INK2\n",
        "mpl.rcParams['axes.titlecolor'] = INK\n",
        "mpl.rcParams['figure.facecolor']= PAPER\n",
        "mpl.rcParams['axes.facecolor']  = PAPER\n",
        "\n",
        "def style_ax(ax, grid_axis='y'):\n",
        "    \"\"\"Strip chartjunk: hide top/right spines, soften remaining ones, add subtle grid.\"\"\"\n",
        "    ax.spines['top'].set_visible(False)\n",
        "    ax.spines['right'].set_visible(False)\n",
        "    ax.spines['left'].set_color(MUTED)\n",
        "    ax.spines['bottom'].set_color(MUTED)\n",
        "    if grid_axis:\n",
        "        ax.grid(axis=grid_axis, alpha=0.25, color=MUTED, linewidth=0.6)\n",
        "    ax.set_axisbelow(True)\n",
        "    return ax\n",
        "\n",
        "print(\"Setup complete.\")"
      ]
    },
