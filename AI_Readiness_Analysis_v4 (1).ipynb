        "USE_MAP = {\n",
        "    'Generating\\xa0content (text or images)': 'Generate content',\n",
        "    'Asking a chatbot for advice, or allowing others to ask a chatbot questions about our own vast information collection': 'Chatbot Q&A',\n",
        "    'Translating\\xa0or transcribing content': 'Translate / transcribe',\n",
        "    'Assisting\\xa0in automating simple repetitive tasks (for example, using virtual office assistants)': 'Automate tasks',\n",
        "    'Interpreting\\xa0our information: scoring, classifying, codifying, or summarizing our information': 'Interpret data',\n",
        "    'Organizing\\xa0our information: restructuring, cleaning, or assigning tags so it can be searched': 'Organize data',\n",
        "    'Organising\\xa0our information: restructuring, cleaning, or assigning tags so it can be searched': 'Organize data',\n",
        "    'Predicting outcomes, patterns, or other things from our data': 'Predict outcomes',\n",
        "}\n",
        "WANT_MAP = {\n",
        "    'Generate content (text or images)': 'Generate content',\n",
        "    'Ask a chatbot for advice, or allow others to ask a chatbot questions about our own vast information collection': 'Chatbot Q&A',\n",
        "    'Translate or transcribe content': 'Translate / transcribe',\n",
        "    'Assist in automating simple repetitive tasks': 'Automate tasks',\n",
        "    'Interpret our information: score, classify, codify, or summarize our information': 'Interpret data',\n",
        "    'Organize our information: restructure, clean, or assign tags so it can be searched': 'Organize data',\n",
        "    'Organise our information: restructure, clean, or assign tags so it can be searched': 'Organize data',\n",
        "    'Predicting outcomes, patterns, or other things from our data': 'Predict outcomes',\n",
        "    'Predict\\xa0outcomes, patterns, or other things from our data': 'Predict outcomes',\n",
        "}\n",
        "\n",
        "CATEGORIES = [\n",
        "    'Generate content', 'Chatbot Q&A', 'Translate / transcribe',\n",
        "    'Automate tasks', 'Interpret data', 'Organize data', 'Predict outcomes',\n",
        "]\n",
        "\n",
        "# Build boolean indicator columns for each (use_X, want_X)\n",
        "for cat in CATEGORIES:\n",
        "    df[f'use_{cat}']  = df['ai_use_list'].apply(lambda r, c=cat: any(USE_MAP.get(x) == c for x in r))\n",
        "    df[f'want_{cat}'] = df['ai_want_list'].apply(lambda r, c=cat: any(WANT_MAP.get(x) == c for x in r))\n",
        "\n",
        "df[[f'use_{c}' for c in CATEGORIES]].sum().sort_values(ascending=False)"
      ]
