        "# Risk-flag rates per behavioral segment\n",
        "def cat_risk(x):\n",
        "    s = str(x).strip().lower()\n",
        "    if 'breach' in s: return 'data_breach'\n",
        "    if 'biased' in s or 'biases' in s: return 'bias'\n",
        "    if 'plagiarism' in s or 'intellectual' in s or 'copyright' in s: return 'plagiarism_ip'\n",
        "    if 'dependency' in s or 'commercial' in s: return 'vendor_dependency'\n",
        "    if 'replac' in s and 'work' in s: return 'worker_replacement'\n",
        "    if 'environ' in s: return 'environment'\n",
        "    return None\n",
        "\n",
        "RISK_LABELS = ['data_breach','bias','plagiarism_ip','vendor_dependency']\n",
        "for r in RISK_LABELS:\n",
        "    df[f'risk_{r}'] = df['ai_risk_list'].apply(lambda l, rr=r: any(cat_risk(x)==rr for x in l))\n",
        "\n",
        "key_segs = [('Heavy Adopters', TEAL), ('Latent Adopters', GOLD),\n",
        "            ('Literacy Gap', '#B8B8B8'), ('AI Resisters', CORAL)]\n",
        "RISK_DISPLAY = ['Data\\nbreaches','Biased\\ndecisions','Plagiarism\\n/ IP loss','Vendor\\ndependency']\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(11, 5), facecolor=PAPER)\n",
        "x = np.arange(len(RISK_LABELS))\n",
        "w = 0.20\n",
        "for i, (seg_name, color) in enumerate(key_segs):\n",
        "    sub = df[df['segment']==seg_name]\n",
        "    rates = [sub[f'risk_{r}'].mean()*100 for r in RISK_LABELS]\n",
        "    bars = ax.bar(x + (i-1.5)*w, rates, w, color=color, edgecolor=PAPER, linewidth=1.5,\n",
        "                  label=f'{seg_name} (n={len(sub)})')\n",
        "    for bar, rate in zip(bars, rates):\n",
        "        ax.text(bar.get_x()+bar.get_width()/2, rate+1, f'{rate:.0f}',\n",
        "                ha='center', fontsize=8.5, color=INK, fontweight='bold')\n",
