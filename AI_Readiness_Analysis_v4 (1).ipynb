      "source": [
        "# --- Not currently using AI ---\n",
        "df['not_using'] = df['ai_use_list'].apply(\n",
        "    lambda r: any('not currently using' in str(x).lower() for x in r)\n",
        ")\n",
        "\n",
        "# --- Counts of uses & risks (excluding 'Other' / boilerplate) ---\n",
        "df['n_uses'] = df['ai_use_list'].apply(\n",
        "    lambda r: len([x for x in r if 'not currently' not in str(x).lower() and 'Other' not in str(x)])\n",
        ")\n",
        "df['n_risks_flagged'] = df['ai_risk_list'].apply(\n",
        "    lambda r: len([x for x in r if 'Other' not in str(x) and len(str(x)) > 3])\n",
        ")\n",
        "\n",
        "# --- Comfort buckets ---\n",
        "df['comfort_bucket'] = pd.cut(\n",
        "    df['person_ai_comfort_raw'],\n",
        "    bins=[-0.1, 3, 6, 8, 10.1],\n",
        "    labels=['Low (0-3)', 'Mid (4-6)', 'High (7-8)', 'Very High (9-10)']\n",
        ")\n",
        "\n",
        "# --- Infrastructure score ---\n",
        "INFRA_COLS = ['collects_data', 'tech_person', 'merl_person', 'cloud_storage', 'data_use_policy']\n",
        "for c in INFRA_COLS:\n",
        "    df[c + '_bin'] = df[c].fillna(0).astype(bool).astype(int)\n",
        "df['infra_score'] = df[[c + '_bin' for c in INFRA_COLS]].sum(axis=1)\n",
        "\n",
        "# --- Cluster names ---\n",
        "# From the data dictionary: cluster3 is HDBSCAN/UMAP on normalized adoption signals.\n",
        "#   1  → AI Consumers (already using; want more)   — n=523\n",
        "#   0  → Late Adopters (curious but stalled)       — n=265\n",
