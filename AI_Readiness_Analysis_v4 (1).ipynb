      "source": [
        "def segment(row):\n",
        "    not_using = row['not_using']\n",
        "    n_uses    = row['n_uses']\n",
        "    n_wants   = row['ai_want_list'].__len__() if isinstance(row['ai_want_list'], list) else len(list(row['ai_want_list']))\n",
        "    comfort   = row['person_ai_comfort_raw']\n",
        "    rr        = row['ai_risk_reward']\n",
        "\n",
        "    # --- non-users ---\n",
        "    if not_using and rr in [1, 2] and n_wants <= 2:\n",
        "        return 'AI Resisters'                # actually anti-AI\n",
        "    if not_using and comfort >= 7 and n_wants >= 3:\n",
        "        return 'Latent Adopters'        # high comfort, high want, no use\n",
        "    if not_using and rr == -1:\n",
        "        return 'Literacy Gap'              # \"I don't understand AI\"\n",
        "    if not_using:\n",
        "        return 'Stalled Curious'           # mid comfort, some aspiration\n",
        "\n",
        "    # --- users ---\n",
        "    if n_uses >= 4:\n",
        "        return 'Heavy Adopters'\n",
        "    if n_uses >= 2 and n_wants >= 3:\n",
        "        return 'Active Aspirants'\n",
        "    if n_uses >= 1 and n_wants <= 2:\n",
        "        return 'Pragmatic Adopters'\n",
        "    return 'Light Users'\n",
        "\n",
        "df['segment'] = df.apply(segment, axis=1)\n",
        "\n",
        "# Show counts\n",
        "df['segment'].value_counts().to_frame('count').assign(\n",
        "    pct=lambda x: (x['count']/len(df)*100).round(0).astype(int).astype(str) + '%'\n",
        ")"
      ]
    },
